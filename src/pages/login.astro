---
import Layout from '../layouts/Layout.astro';

const isAuthenticated = Astro.cookies.get('portal_auth')?.value === 'authenticated';
if (isAuthenticated) {
    return Astro.redirect('/dashboard');
}
---

<Layout title="Content Portal - Inloggen">
    <div class="max-w-md mx-auto mt-8 relative z-10">
        <div class="glass-panel p-10 rounded-3xl shadow-2xl relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-brand/10 to-transparent pointer-events-none"></div>
            <div class="text-center mb-8 relative">
                <div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/10 text-white shadow-[0_0_15px_rgba(255,255,255,0.1)] flex items-center justify-center mx-auto mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                    </svg>
                </div>
                <h1 class="text-3xl font-display font-bold text-white tracking-tight">Beheerders Inlog</h1>
                <p class="text-slate-400 text-sm mt-2">Log in om het dashboard te bekijken en instellingen te beheren.</p>
            </div>

            <form id="loginForm" class="space-y-6 relative">
                <div class="space-y-2">
                    <label for="username" class="block text-sm font-bold text-slate-300">Gebruikersnaam</label>
                    <input
                        type="text"
                        id="username"
                        name="username"
                        required
                        autocomplete="username"
                        class="w-full px-5 py-4 bg-[#0A0A0A] border border-white/10 rounded-xl text-white placeholder-slate-600 focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition-all"
                        placeholder="Bijv. admin"
                    />
                </div>

                <div class="space-y-2">
                    <label for="password" class="block text-sm font-bold text-slate-300">Wachtwoord</label>
                    <input
                        type="password"
                        id="password"
                        name="password"
                        required
                        autocomplete="current-password"
                        class="w-full px-5 py-4 bg-[#0A0A0A] border border-white/10 rounded-xl text-white placeholder-slate-600 focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition-all"
                        placeholder="••••••••"
                    />
                </div>

                <div id="errorMessage" class="hidden bg-red-500/10 border border-red-500/20 text-red-500 text-sm p-4 rounded-xl font-medium"></div>

                <button
                    type="submit"
                    id="submitBtn"
                    class="w-full bg-white text-black font-bold py-4 rounded-xl hover:bg-gray-200 transition-all duration-200 flex items-center justify-center gap-2 mt-2 shadow-[0_0_20px_rgba(255,255,255,0.2)] hover:shadow-[0_0_25px_rgba(255,255,255,0.4)]"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
                    </svg>
                    Inloggen
                </button>
            </form>
        </div>
    </div>
</Layout>

<script>
    const form = document.getElementById('loginForm') as HTMLFormElement;
    const errorMessage = document.getElementById('errorMessage') as HTMLDivElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorMessage.classList.add('hidden');
        submitBtn.disabled = true;
        submitBtn.textContent = 'Bezig met inloggen...';

        const username = (document.getElementById('username') as HTMLInputElement).value;
        const password = (document.getElementById('password') as HTMLInputElement).value;

        try {
            const response = await fetch('/api/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, password }),
            });

            const data = await response.json();

            if (data.success) {
                window.location.href = '/dashboard';
            } else {
                errorMessage.textContent = data.error || 'Inloggen mislukt';
                errorMessage.classList.remove('hidden');
                submitBtn.disabled = false;
                submitBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" /></svg> Inloggen`;
            }
        } catch (error) {
            errorMessage.textContent = 'Er ging iets mis. Probeer het opnieuw.';
            errorMessage.classList.remove('hidden');
            submitBtn.disabled = false;
            submitBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" /></svg> Inloggen`;
        }
    });
</script>
