---
import Layout from '../layouts/Layout.astro';
import db from '../db/database';

let parsedTeamMembers: string[] = [];
try {
    const res = await db.execute('SELECT team_members FROM settings WHERE id = 1');
    if (res.rows.length > 0 && res.rows[0].team_members) {
        parsedTeamMembers = JSON.parse(String(res.rows[0].team_members));
    }
} catch (e) {}
---

<Layout title="Social Media Aanleveren">
    <div class="space-y-12 max-w-4xl mx-auto pb-20 reveal">
        <div class="max-w-7xl mx-auto pt-4 relative z-10">
            <a href="/" class="inline-flex items-center gap-2 text-slate-500 hover:text-slate-900 font-semibold transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                </svg>
                Terug naar overzicht
            </a>
        </div>
        <div class="text-center space-y-4 -mt-4">
            <div class="inline-block px-4 py-1.5 rounded-full bg-brand/10 border border-brand/20 text-sm font-semibold text-brand mb-2 shadow-sm">
                Voor intern gebruik
            </div>
            <h1 class="text-4xl md:text-5xl font-heading font-bold text-slate-900 leading-tight">
                Deel jouw <span class="bg-gradient-to-r from-brand to-cyan-500 bg-clip-text text-transparent">Social Update</span>
            </h1>
            <p class="text-slate-500 text-lg max-w-2xl mx-auto leading-relaxed">
                Heb je een project, mijlpaal of leuke post voor op social media? Vul dit formulier in (max 2 min) en stuur het direct door.
            </p>
        </div>

        <form id="submissionForm" class="max-w-3xl mx-auto bg-white border border-slate-100 shadow-[0_8px_30px_rgb(0,0,0,0.04)] p-8 md:p-12 rounded-3xl relative overflow-hidden space-y-8">
            <!-- Top shimmer effect -->
            <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-brand to-cyan-500"></div>

            <div id="formFeedback" class="hidden p-4 rounded-xl text-center font-semibold mb-4 transition-all"></div>

            <!-- Wat? -->
            <div class="space-y-2">
                <label for="wat" class="block font-heading font-semibold text-slate-800 text-lg">Wat? <span class="text-brand">*</span></label>
                <p class="text-sm text-slate-500 mb-2">Korte titel of onderwerp van je update.</p>
                <input type="text" id="wat" name="wat" required
                    class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:bg-white focus:outline-none focus:border-brand/50 focus:ring-4 focus:ring-brand/10 transition-all duration-300 font-medium placeholder-slate-400"
                    placeholder="Bijv: Opening nieuw kantoor..." />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Waar? -->
                <div class="space-y-2">
                    <label for="waar" class="block font-heading font-semibold text-slate-800 text-lg">Waar?</label>
                    <input type="text" id="waar" name="waar"
                        class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:bg-white focus:outline-none focus:border-brand/50 focus:ring-4 focus:ring-brand/10 transition-all duration-300 font-medium placeholder-slate-400"
                        placeholder="Bijv: Amsterdam / Online" />
                </div>

                <!-- Waarom? -->
                <div class="space-y-2">
                    <label for="waarom" class="block font-heading font-semibold text-slate-800 text-lg">Waarom? (Doel)</label>
                    <input type="text" id="waarom" name="waarom"
                        class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:bg-white focus:outline-none focus:border-brand/50 focus:ring-4 focus:ring-brand/10 transition-all duration-300 font-medium placeholder-slate-400"
                        placeholder="Bijv: Kennis delen, Werving..." />
                </div>
            </div>

            <!-- Wanneer plaatsen? -->
            <div class="space-y-3">
                <label class="block font-heading font-semibold text-slate-800 text-lg">Wanneer plaatsen? <span class="text-brand">*</span></label>
                <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
                    <label class="cursor-pointer relative">
                        <input type="radio" name="timing" value="Spoed" class="peer sr-only" required>
                        <div class="p-3 rounded-xl bg-slate-50 border border-slate-200 peer-checked:border-brand peer-checked:bg-brand/5 hover:bg-slate-100 transition-all font-medium text-slate-600 flex justify-center items-center gap-1.5">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-4 text-orange-500">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.866 8.21 8.21 0 0 0 3 2.48Z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z" />
                            </svg>
                            Spoed
                        </div>
                    </label>
                    <label class="cursor-pointer relative">
                        <input type="radio" name="timing" value="Deze week" class="peer sr-only">
                        <div class="p-3 rounded-xl bg-slate-50 border border-slate-200 peer-checked:border-brand peer-checked:bg-brand/5 hover:bg-slate-100 transition-all font-medium text-slate-600 flex justify-center items-center gap-1.5">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-4 text-brand">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                            </svg>
                            Deze week
                        </div>
                    </label>
                    <label class="cursor-pointer relative">
                        <input type="radio" name="timing" value="Geen haast" class="peer sr-only">
                        <div class="p-3 rounded-xl bg-slate-50 border border-slate-200 peer-checked:border-brand peer-checked:bg-brand/5 hover:bg-slate-100 transition-all font-medium text-slate-600 flex justify-center items-center gap-1.5">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-4 text-slate-500">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 15.15V19.5m-6-4.35V19.5m-3-4.35V19.5m12-4.35V15.15M6.75 12h10.5M3.75 6.75A2.25 2.25 0 0 1 6 4.5h12a2.25 2.25 0 0 1 2.25 2.25V12a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 12V6.75Z" />
                            </svg>
                            Geen haast
                        </div>
                    </label>
                    <label class="cursor-pointer relative col-span-2 md:col-span-3">
                        <input type="radio" name="timing" value="Anders" class="peer sr-only" id="timingCustom">
                        <div class="p-3 rounded-xl bg-slate-50 border border-slate-200 peer-checked:border-brand peer-checked:bg-brand/5 hover:bg-slate-100 transition-all text-center font-medium text-slate-600 flex flex-wrap items-center justify-center gap-2">
                             <div class="flex items-center gap-1.5">
                                 <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-4 text-slate-400">
                                     <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                                 </svg>
                                 Zelf kiezen:
                             </div>
                             <input type="date" name="customDate" class="bg-transparent border-b border-slate-300 text-slate-900 focus:border-brand outline-none text-sm px-1 min-w-[120px]" onclick="document.getElementById('timingCustom').checked = true">
                        </div>
                    </label>
                </div>
            </div>

            <!-- Met welke partners? -->
            <div class="space-y-2">
                <label for="partners" class="block font-heading font-semibold text-slate-800 text-lg">Met welke partners of collega's?</label>
                <p class="text-sm text-slate-500 mb-2">Wie moeten we taggen of noemen?</p>
                <input type="text" id="partners" name="partners"
                    class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:bg-white focus:outline-none focus:border-brand/50 focus:ring-4 focus:ring-brand/10 transition-all duration-300 font-medium placeholder-slate-400"
                    placeholder="@Partner1, @Collega..." />
            </div>

            <!-- Achtergrondinformatie (Was: Jouw verhaal) -->
            <div class="space-y-2">
                <div class="flex items-center justify-between">
                    <label for="toelichting" class="block font-heading font-semibold text-slate-800 text-lg">Korte toelichting</label>
                    <button type="button" id="micButton" class="text-slate-400 hover:text-brand transition-colors p-2 rounded-full hover:bg-slate-100 hidden group-focus-within:block" title="Spreek toelichting in">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z" />
                        </svg>
                    </button>
                </div>
                <p class="text-sm text-slate-500 mb-2">Wat is de context van dit bericht?</p>
                <div class="relative">
                    <textarea id="toelichting" name="toelichting" rows="3"
                        class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:bg-white focus:outline-none focus:border-brand/50 focus:ring-4 focus:ring-brand/10 transition-all duration-300 font-medium placeholder-slate-400 resize-none"
                        placeholder="Typ hier je toelichting..."></textarea>
                    <div id="micStatus" class="absolute top-2 right-2 hidden">
                        <span class="flex h-3 w-3">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-3 w-3 bg-red-500"></span>
                        </span>
                    </div>
                </div>
            </div>

            <!-- Foto's/video's (File Input & Link) -->
            <div class="space-y-4">
                <div>
                    <label class="block font-heading font-semibold text-slate-800 text-lg">Foto's / Video's Uploaden</label>
                    <p class="text-sm text-slate-500 mb-4">Selecteer direct beelden vanaf je apparaat of vul een WeTransfer link in.</p>
                </div>

                <!-- Custom Drag & Drop / File Input -->
                <div class="relative group cursor-pointer">
                    <input type="file" id="fotos" name="fotosUpload" multiple accept="image/*,video/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
                    <div id="dropzone" class="w-full p-8 rounded-2xl border-2 border-dashed border-slate-300 bg-slate-50 group-hover:bg-slate-100 transition-all text-center flex flex-col items-center justify-center gap-3">
                        <div class="w-12 h-12 rounded-full bg-brand/5 text-brand flex items-center justify-center border border-brand/10">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0 3 3m-3-3-3 3M6.75 19.5a4.5 4.5 0 0 1-1.41-8.775 5.25 5.25 0 0 1 10.233-2.33 3 3 0 0 1 3.758 3.848A3.752 3.752 0 0 1 18 19.5H6.75Z" />
                            </svg>
                        </div>
                        <div>
                            <span class="font-bold text-slate-800">Klik hier</span> of sleep bestanden
                            <p class="text-xs text-slate-500 mt-1">Ondersteunt: JPG, PNG, MP4, MOV</p>
                        </div>
                        <!-- File Preview Container -->
                        <div id="filePreview" class="w-full mt-4 flex flex-wrap gap-2 justify-center empty:hidden"></div>
                    </div>
                </div>

                <!-- Fallback Link Input -->
                <div class="flex items-center gap-3">
                    <div class="text-sm text-slate-500 font-medium whitespace-nowrap">Of plak een link:</div>
                    <input type="text" id="fotosLink" name="fotosLink"
                        class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:bg-white focus:outline-none focus:border-brand/50 focus:ring-4 focus:ring-brand/10 transition-all duration-300 font-medium placeholder-slate-400 text-sm"
                        placeholder="bijv: https://we.tl/..." />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Contactpersoon -->
                <div class="space-y-2">
                    <label for="contactPersoon" class="block font-heading font-semibold text-slate-800 text-lg">Contactpersoon</label>
                    {parsedTeamMembers.length > 0 ? (
                        <select id="contactPersoon" name="contactPersoon" class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:bg-white focus:outline-none focus:border-brand/50 focus:ring-4 focus:ring-brand/10 transition-all duration-300 font-medium appearance-none cursor-pointer">
                            <option value="">Selecteer wie je bent...</option>
                            {parsedTeamMembers.map(member => (
                                <option value={member}>{member}</option>
                            ))}
                            <option value="Anders">- Ander persoon -</option>
                        </select>
                    ) : (
                        <input type="text" id="contactPersoon" name="contactPersoon"
                            class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:bg-white focus:outline-none focus:border-brand/50 focus:ring-4 focus:ring-brand/10 transition-all duration-300 font-medium placeholder-slate-400"
                            placeholder="Jouw Naam" />
                    )}
                </div>

                <!-- Contactgegevens -->
                <div class="space-y-2">
                    <label for="contactGegevens" class="block font-heading font-semibold text-slate-800 text-lg">Contactgegevens</label>
                    <input type="text" id="contactGegevens" name="contactGegevens"
                        class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:bg-white focus:outline-none focus:border-brand/50 focus:ring-4 focus:ring-brand/10 transition-all duration-300 font-medium placeholder-slate-400"
                        placeholder="E-mailadres of 06-nummer" />
                </div>
            </div>

            <!-- Verplichtingen -->
             <div class="space-y-2">
                <label for="verplichtingen" class="block font-heading font-semibold text-slate-800 text-lg">Verplichtingen</label>
                <input type="text" id="verplichtingen" name="verplichtingen"
                    class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:bg-white focus:outline-none focus:border-brand/50 focus:ring-4 focus:ring-brand/10 transition-all duration-300 font-medium placeholder-slate-400"
                    placeholder="Logo's, tijdstippen, etc." />
            </div>

            <div class="pt-4 border-t border-slate-100">
                <button type="submit" id="submitBtn"
                    class="bg-brand hover:brightness-95 group w-full text-brand-text font-heading font-bold text-lg py-5 rounded-xl shadow-lg shadow-brand/20 hover:shadow-xl hover:shadow-brand/30 hover:-translate-y-0.5 transition-all duration-300 flex items-center justify-center gap-2">
                    <span id="submitText">Update Indienen</span>
                    <svg id="submitIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5 group-hover:translate-x-1 transition-transform">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
                    </svg>                      
                </button>
            </div>
        </form>
    </div>
</Layout>

<script>
    const form = document.getElementById('submissionForm') as HTMLFormElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const submitText = document.getElementById('submitText');
    const formFeedback = document.getElementById('formFeedback');
    
    // Voice to Text Logic
    const micButton = document.getElementById('micButton');
    const micStatus = document.getElementById('micStatus');
    const toelichtingInput = document.getElementById('toelichting') as HTMLTextAreaElement;
    
    // Check browser support
    if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
        micButton?.classList.remove('hidden');
        
        // @ts-ignore
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        const recognition = new SpeechRecognition();
        
        recognition.continuous = true; // Keep listening
        recognition.lang = 'nl-NL';
        recognition.interimResults = true; // Live feedback
        
        let isRecording = false;
        let finalTranscript = '';
        let originalText = '';

        recognition.onstart = () => {
            isRecording = true;
            micButton?.classList.add('text-red-500', 'bg-red-50');
            if (micButton) micButton.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 7.5A2.25 2.25 0 0 1 7.5 5.25h9a2.25 2.25 0 0 1 2.25 2.25v9a2.25 2.25 0 0 1-2.25 2.25h-9a2.25 2.25 0 0 1-2.25-2.25v-9Z" /></svg>`;
            micStatus?.classList.remove('hidden');
            
            if (toelichtingInput) {
                originalText = toelichtingInput.value;
                if (originalText && !originalText.endsWith(' ')) originalText += ' ';
            }
            finalTranscript = '';
        };
        
        recognition.onend = () => {
            isRecording = false;
            micButton?.classList.remove('text-red-500', 'bg-red-50');
            if (micButton) micButton.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z" /></svg>`;
            micStatus?.classList.add('hidden');
        };
        
        recognition.onresult = (event: any) => {
            let interimTranscript = '';
            for (let i = event.resultIndex; i < event.results.length; ++i) {
                if (event.results[i].isFinal) {
                    finalTranscript += event.results[i][0].transcript;
                } else {
                    interimTranscript += event.results[i][0].transcript;
                }
            }
            if (toelichtingInput) {
                toelichtingInput.value = originalText + finalTranscript + interimTranscript;
            }
        };
        
        micButton?.addEventListener('click', () => {
            if (isRecording) {
                recognition.stop();
            } else {
                recognition.start();
            }
        });
    }

    // File Upload Preview Logic
    const fileInput = document.getElementById('fotos') as HTMLInputElement;
    const dropzone = document.getElementById('dropzone');
    const filePreview = document.getElementById('filePreview');

    if (fileInput && dropzone && filePreview) {
        fileInput.addEventListener('change', (e) => {
            filePreview.innerHTML = ''; // Clear previous
            const files = fileInput.files;
            if (files && files.length > 0) {
                Array.from(files).forEach(file => {
                    const badge = document.createElement('div');
                    badge.className = 'px-3 py-1 bg-white border border-brand/20 text-brand text-xs font-bold rounded-lg shadow-sm truncate max-w-[150px] flex items-center gap-1';
                    
                    const icon = file.type.startsWith('video') ? '🎥' : '🖼️';
                    badge.innerHTML = `<span>${icon}</span><span class="truncate">${file.name}</span>`;
                    filePreview.appendChild(badge);
                });
            }
        });

        // Drag & Drop visual feedback
        fileInput.addEventListener('dragover', () => dropzone.classList.add('bg-brand/20', 'border-brand/60'));
        fileInput.addEventListener('dragleave', () => dropzone.classList.remove('bg-brand/20', 'border-brand/60'));
        fileInput.addEventListener('drop', () => dropzone.classList.remove('bg-brand/20', 'border-brand/60'));
    }

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!submitBtn || !submitText || !formFeedback) return;
        
        submitBtn.disabled = true;
        submitBtn.classList.add('opacity-75', 'cursor-not-allowed');
        submitText.innerText = 'Bezig met opslaan...';
        formFeedback.classList.add('hidden');
        
        const formData = new FormData(form);
        
        try {
            const response = await fetch('/api/submit-social', {
                method: 'POST',
                body: formData
            });
            
            const result = await response.json();
            
            if (result.success) {
                formFeedback.innerText = result.message;
                formFeedback.className = 'p-4 rounded-xl text-center font-semibold mb-4 bg-green-100 text-green-800 transition-all block';
                form.reset();
            } else {
                throw new Error(result.error || 'Er ging iets fout bij het verzenden.');
            }
        } catch (error: any) {
            formFeedback.innerText = error.message;
            formFeedback.className = 'p-4 rounded-xl text-center font-semibold mb-4 bg-red-100 text-red-800 transition-all block';
        } finally {
            submitBtn.disabled = false;
            submitBtn.classList.remove('opacity-75', 'cursor-not-allowed');
            submitText.innerText = 'Update Indienen';
        }
    });
</script>
