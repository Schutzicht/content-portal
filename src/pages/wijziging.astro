---
import Layout from '../layouts/Layout.astro';
import db from '../db/database';

const settingsRes = await db.execute(`SELECT * FROM settings WHERE id = 1`);
const settings = settingsRes.rows[0] || {};
const teamMembers = String(settings.team_members || '[]');
let parsedTeamMembers: string[] = [];
try { parsedTeamMembers = JSON.parse(teamMembers); } catch(e) {}
---

<Layout title="Website Wijziging Doorvoeren">
    <div class="space-y-10 reveal max-w-4xl mx-auto pb-20">
        <div class="max-w-7xl mx-auto pt-4 relative z-10">
            <a href="/" class="inline-flex items-center gap-2 text-slate-500 hover:text-slate-900 font-semibold transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                </svg>
                Terug naar overzicht
            </a>
        </div>
        <div class="text-center space-y-4">
            <div class="inline-block px-4 py-1.5 rounded-full bg-emerald-100 border border-emerald-200 text-sm font-semibold text-emerald-700 mb-2 shadow-sm">
                Voor intern gebruik
            </div>
            <h1 class="text-4xl md:text-5xl font-display font-bold text-slate-900 tracking-tight">
                Wijziging <span class="bg-gradient-to-r from-emerald-400 to-teal-500 bg-clip-text text-transparent">Doorvoeren</span>
            </h1>
            <p class="text-slate-500 text-lg">Geef snel een wijziging voor op de website door.</p>
        </div>

        <div class="bg-white border border-slate-100 p-8 md:p-12 rounded-[2.5rem] shadow-[0_8px_30px_rgb(0,0,0,0.04)] relative overflow-hidden">
            <!-- Top shimmer effect -->
            <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-emerald-500 to-teal-500"></div>

            <form id="wijzigingForm" class="space-y-8" action="/api/submit-wijziging" method="POST" enctype="multipart/form-data">
                
                <div class="space-y-2">
                    <label class="block font-heading font-semibold text-slate-800 text-lg">
                        Wat moet er gewijzigd worden? <span class="text-emerald-500">*</span>
                    </label>
                    <input type="text" name="wat" required 
                        placeholder="Bijv: Nieuwe partner toevoegen"
                        class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:bg-white focus:outline-none focus:border-emerald-500/50 focus:ring-4 focus:ring-emerald-500/10 transition-all font-medium placeholder-slate-400" />
                </div>

                <div class="space-y-2">
                    <label class="block font-heading font-semibold text-slate-800 text-lg">
                        Details van de wijziging <span class="text-emerald-500">*</span>
                    </label>
                    <p class="text-sm text-slate-500">Omschrijf precies wat we moeten doen. Geef ook eventuele teksten op.</p>
                    <textarea name="details" required rows="6"
                        placeholder="Voeg het logo van Bedrijf X toe en vermeld in de bodytekst dat..."
                        class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:bg-white focus:outline-none focus:border-emerald-500/50 focus:ring-4 focus:ring-emerald-500/10 transition-all font-medium placeholder-slate-400 resize-none"></textarea>
                </div>

                <div class="space-y-2">
                    <label class="block font-heading font-semibold text-slate-800 text-lg">
                        Waar op de website bevindt dit zich? <span class="text-slate-400 font-normal text-sm ml-2">(Optioneel)</span>
                    </label>
                    <input type="text" name="waar" 
                        placeholder="Bijv: Op de partner pagina of www.domein.nl/partners"
                        class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:bg-white focus:outline-none focus:border-emerald-500/50 focus:ring-4 focus:ring-emerald-500/10 transition-all font-medium placeholder-slate-400" />
                </div>

                <div class="space-y-2">
                    <label class="block font-heading font-semibold text-slate-800 text-lg">
                        Beeldmateriaal / Bestanden toevoegen <span class="text-slate-400 font-normal text-sm ml-2">(Optioneel)</span>
                    </label>
                    <div class="relative group">
                        <div class="absolute inset-0 bg-slate-50 rounded-2xl border-2 border-dashed border-slate-300 group-hover:bg-slate-100 transition-colors"></div>
                        <input type="file" name="fotos" multiple class="relative z-10 w-full h-32 opacity-0 cursor-pointer" id="fileInput" />
                        <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none text-emerald-600">
                            <div class="w-12 h-12 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center border border-emerald-200 mb-3">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-6">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0 3 3m-3-3-3 3M6.75 19.5a4.5 4.5 0 0 1-1.41-8.775 5.25 5.25 0 0 1 10.233-2.33 3 3 0 0 1 3.758 3.848A3.752 3.752 0 0 1 18 19.5H6.75Z" />
                                </svg>
                            </div>
                            <span class="font-bold text-slate-800" id="fileLabel">Klik of sleep bestanden hierheen</span>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4 border-t border-slate-100">
                    <div class="space-y-2">
                        <label class="block font-heading font-semibold text-slate-800">
                            Contactpersoon <span class="text-emerald-500">*</span>
                        </label>
                        <div class="relative">
                            <select name="contactPersoon" required class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:bg-white focus:outline-none focus:border-emerald-500/50 focus:ring-4 focus:ring-emerald-500/10 transition-all font-medium appearance-none cursor-pointer">
                                <option value="" disabled selected>Kies een teamlid</option>
                                {parsedTeamMembers.map((member) => (
                                    <option value={member}>{member}</option>
                                ))}
                            </select>
                            <div class="absolute right-5 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                                </svg>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="block font-heading font-semibold text-slate-800">
                            Contactgegevens <span class="text-slate-400 font-normal text-sm ml-1">(Optioneel)</span>
                        </label>
                        <input type="text" name="contactGegevens" 
                            placeholder="Telefoonnummer / Email"
                            class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:bg-white focus:outline-none focus:border-emerald-500/50 focus:ring-4 focus:ring-emerald-500/10 transition-all font-medium placeholder-slate-400" />
                    </div>
                </div>

                <div class="pt-6">
                    <button type="submit" id="submitBtn" class="bg-emerald-600 hover:bg-emerald-700 group w-full text-white font-heading font-bold text-lg py-5 rounded-xl shadow-lg shadow-emerald-500/20 hover:shadow-xl hover:shadow-emerald-500/30 hover:-translate-y-0.5 transition-all duration-300 flex items-center justify-center gap-2">
                        <span>Wijziging Indienen</span>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5 group-hover:translate-x-1 transition-transform">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
                        </svg>
                    </button>
                    <div id="feedbackMessage" class="hidden mt-4 p-4 rounded-xl text-center font-semibold transition-all"></div>
                </div>
            </form>
        </div>
    </div>
</Layout>

<script>
    const fileInput = document.getElementById('fileInput') as HTMLInputElement;
    const fileLabel = document.getElementById('fileLabel');

    fileInput?.addEventListener('change', (e) => {
        const target = e.target as HTMLInputElement;
        if (target.files && target.files.length > 0) {
            fileLabel!.textContent = `${target.files.length} bestand(en) geselecteerd`;
            fileLabel!.classList.add('text-emerald-700');
        } else {
            fileLabel!.textContent = 'Klik of sleep bestanden hierheen';
            fileLabel!.classList.remove('text-emerald-700');
        }
    });

    const form = document.getElementById('wijzigingForm') as HTMLFormElement;
    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const btn = document.getElementById('submitBtn') as HTMLButtonElement;
        const feedback = document.getElementById('feedbackMessage');
        const btnText = btn.querySelector('span');
        const originalText = btnText?.textContent || 'Wijziging Indienen';
        
        btn.disabled = true;
        btn.classList.add('opacity-75', 'cursor-not-allowed');
        if (btnText) btnText.textContent = 'Bezig met verzenden...';
        
        try {
            const formData = new FormData(form);
            const response = await fetch('/api/submit-wijziging', {
                method: 'POST',
                body: formData
            });
            
            const result = await response.json();
            
            if (result.success) {
                form.reset();
                if (fileLabel) {
                    fileLabel.textContent = 'Klik of sleep bestanden hierheen';
                    fileLabel.classList.remove('text-emerald-700');
                }
                
                if (feedback) {
                    feedback.textContent = 'Wijziging is succesvol verstuurd! Bedankt.';
                    feedback.className = 'mt-4 p-4 rounded-xl text-center font-semibold bg-emerald-100 text-emerald-800 transition-all block';
                }
            } else {
                throw new Error(result.error);
            }
        } catch (error) {
            if (feedback) {
                feedback.textContent = 'Er ging iets mis bij het verzenden. Probeer het later opnieuw.';
                feedback.className = 'mt-4 p-4 rounded-xl text-center font-semibold bg-red-100 text-red-800 transition-all block';
            }
        } finally {
            btn.disabled = false;
            btn.classList.remove('opacity-75', 'cursor-not-allowed');
            if (btnText) btnText.textContent = originalText;
            
            setTimeout(() => {
                if (feedback) {
                    feedback.classList.replace('block', 'hidden');
                }
            }, 5000);
        }
    });
</script>
