---
import Layout from '../layouts/Layout.astro';
import db from '../db/database';

let parsedTeamMembers: string[] = [];
try {
    const res = await db.execute('SELECT team_members FROM settings WHERE id = 1');
    if (res.rows.length > 0 && res.rows[0].team_members) {
        parsedTeamMembers = JSON.parse(String(res.rows[0].team_members));
    }
} catch (e) {}
---

<Layout title="Nieuwsartikel Aanleveren">
    <div class="space-y-12 max-w-4xl mx-auto pb-20 reveal">
        <div class="max-w-7xl mx-auto pt-4">
            <a href="/" class="inline-flex items-center gap-2 text-slate-400 hover:text-white font-semibold transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                </svg>
                Terug naar overzicht
            </a>
        </div>
        <div class="text-center space-y-4 -mt-4">
            <div class="inline-block px-4 py-1.5 rounded-full bg-violet-500/10 border border-violet-500/20 text-sm font-semibold text-violet-400 mb-2 shadow-sm">
                Voor intern gebruik
            </div>
            <h1 class="text-4xl md:text-5xl font-heading font-bold text-white leading-tight">
                Lever een <span class="bg-gradient-to-r from-violet-500 to-purple-500 bg-clip-text text-transparent">Nieuwsartikel</span> aan
            </h1>
            <p class="text-slate-400 text-lg max-w-2xl mx-auto leading-relaxed">
                Heb je een interessant artikel of een belangrijk nieuwtje voor op de website? Deel het via dit formulier.
            </p>
        </div>

        <form id="submissionForm" class="max-w-3xl mx-auto glass-panel p-8 md:p-12 rounded-3xl relative overflow-hidden space-y-8">
            <!-- Top shimmer effect -->
            <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-violet-500 to-purple-500"></div>

            <div id="formFeedback" class="hidden p-4 rounded-xl text-center font-semibold mb-4 transition-all"></div>

            <!-- Titel -->
            <div class="space-y-2">
                <label for="wat" class="block font-heading font-semibold text-white text-lg">Titel van het artikel <span class="text-violet-500">*</span></label>
                <p class="text-sm text-slate-400 mb-2">Een pakkende titel voor het nieuwsartikel.</p>
                <input type="text" id="wat" name="wat" required
                    class="w-full px-5 py-4 rounded-xl bg-[#0A0A0A] border border-white/10 text-white focus:outline-none focus:border-violet-500/50 focus:ring-4 focus:ring-violet-500/10 transition-all duration-300 font-medium placeholder-slate-600"
                    placeholder="Bijv: Nieuwe samenwerking..." />
            </div>

            <!-- Inhoud -->
            <div class="space-y-2">
                <div class="flex items-center justify-between">
                    <label for="toelichting" class="block font-heading font-semibold text-white text-lg">Artikel / Inhoud <span class="text-violet-500">*</span></label>
                    <button type="button" id="micButton" class="text-slate-400 hover:text-violet-400 transition-colors p-2 rounded-full hover:bg-white/5 hidden group-focus-within:block" title="Spreek tekst in">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z" />
                        </svg>
                    </button>
                </div>
                <p class="text-sm text-slate-400 mb-2">De volledige tekst of de kernpunten voor het artikel.</p>
                <div class="relative">
                    <textarea id="toelichting" name="toelichting" rows="6" required
                        class="w-full px-5 py-4 rounded-xl bg-[#0A0A0A] border border-white/10 text-white focus:outline-none focus:border-violet-500/50 focus:ring-4 focus:ring-violet-500/10 transition-all duration-300 font-medium placeholder-slate-600 resize-none"
                        placeholder="Typ hier het artikel of de inhoud..."></textarea>
                    <div id="micStatus" class="absolute top-2 right-2 hidden">
                        <span class="flex h-3 w-3">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-3 w-3 bg-red-500"></span>
                        </span>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Doelgroep -->
                <div class="space-y-2">
                    <label for="waarom" class="block font-heading font-semibold text-white text-lg">Voor wie is dit bedoeld?</label>
                    <input type="text" id="waarom" name="waarom"
                        class="w-full px-5 py-4 rounded-xl bg-[#0A0A0A] border border-white/10 text-white focus:outline-none focus:border-violet-500/50 focus:ring-4 focus:ring-violet-500/10 transition-all duration-300 font-medium placeholder-slate-600"
                        placeholder="Bijv: Klanten, partners..." />
                </div>
                
                <!-- Wanneer plaatsen? -->
                <div class="space-y-2">
                    <label for="wanneer" class="block font-heading font-semibold text-white text-lg">Wanneer publiceren?</label>
                    <input type="text" id="wanneer" name="wanneer"
                        class="w-full px-5 py-4 rounded-xl bg-[#0A0A0A] border border-white/10 text-white focus:outline-none focus:border-violet-500/50 focus:ring-4 focus:ring-violet-500/10 transition-all duration-300 font-medium placeholder-slate-600"
                        placeholder="Bijv: Zo snel mogelijk, 1 mei" />
                </div>
            </div>

            <!-- Betrokkenen -->
            <div class="space-y-2">
                <label for="partners" class="block font-heading font-semibold text-white text-lg">Betrokkenen / Bronnen</label>
                <input type="text" id="partners" name="partners"
                    class="w-full px-5 py-4 rounded-xl bg-[#0A0A0A] border border-white/10 text-white focus:outline-none focus:border-violet-500/50 focus:ring-4 focus:ring-violet-500/10 transition-all duration-300 font-medium placeholder-slate-600"
                    placeholder="Namen van betrokkenen of links naar bronmateriaal..." />
            </div>

            <!-- Foto's/video's (File Input & Link) -->
            <div class="space-y-4">
                <div>
                    <label class="block font-heading font-semibold text-white text-lg">Foto's / Video's Uploaden</label>
                    <p class="text-sm text-slate-400 mb-4">Selecteer direct beelden vanaf je apparaat of vul een WeTransfer link in.</p>
                </div>

                <!-- Custom Drag & Drop / File Input -->
                <div class="relative group cursor-pointer">
                    <input type="file" id="fotos" name="fotosUpload" multiple accept="image/*,video/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
                    <div id="dropzone" class="w-full p-8 rounded-2xl border-2 border-dashed border-white/20 bg-white/5 group-hover:bg-white/10 transition-all text-center flex flex-col items-center justify-center gap-3">
                        <div class="w-12 h-12 rounded-full bg-white/10 text-violet-400 flex items-center justify-center border border-white/5">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0 3 3m-3-3-3 3M6.75 19.5a4.5 4.5 0 0 1-1.41-8.775 5.25 5.25 0 0 1 10.233-2.33 3 3 0 0 1 3.758 3.848A3.752 3.752 0 0 1 18 19.5H6.75Z" />
                            </svg>
                        </div>
                        <div>
                            <span class="font-bold text-white">Klik hier</span> of sleep bestanden
                            <p class="text-xs text-slate-400 mt-1">Ondersteunt: JPG, PNG, MP4, MOV</p>
                        </div>
                        <!-- File Preview Container -->
                        <div id="filePreview" class="w-full mt-4 flex flex-wrap gap-2 justify-center empty:hidden"></div>
                    </div>
                </div>

                <!-- Fallback Link Input -->
                <div class="flex items-center gap-3">
                    <div class="text-sm text-slate-400 font-medium whitespace-nowrap">Of plak een link:</div>
                    <input type="text" id="fotosLink" name="fotosLink"
                        class="w-full px-4 py-3 rounded-xl bg-[#0A0A0A] border border-white/10 text-white focus:outline-none focus:border-violet-500/50 focus:ring-4 focus:ring-violet-500/10 transition-all duration-300 font-medium placeholder-slate-600 text-sm"
                        placeholder="bijv: https://we.tl/..." />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Auteur / Contactpersoon -->
                <div class="space-y-2">
                    <label for="contactPersoon" class="block font-heading font-semibold text-white text-lg">Afzender / Auteur</label>
                    {parsedTeamMembers.length > 0 ? (
                        <select id="contactPersoon" name="contactPersoon" class="w-full px-5 py-4 rounded-xl bg-[#0A0A0A] border border-white/10 text-white focus:outline-none focus:border-violet-500/50 focus:ring-4 focus:ring-violet-500/10 transition-all duration-300 font-medium appearance-none cursor-pointer">
                            <option value="">Selecteer wie je bent...</option>
                            {parsedTeamMembers.map(member => (
                                <option value={member}>{member}</option>
                            ))}
                            <option value="Anders">- Ander persoon -</option>
                        </select>
                    ) : (
                        <input type="text" id="contactPersoon" name="contactPersoon"
                            class="w-full px-5 py-4 rounded-xl bg-[#0A0A0A] border border-white/10 text-white focus:outline-none focus:border-violet-500/50 focus:ring-4 focus:ring-violet-500/10 transition-all duration-300 font-medium placeholder-slate-600"
                            placeholder="Jouw Naam" />
                    )}
                </div>

                <!-- Contactgegevens -->
                <div class="space-y-2">
                    <label for="contactGegevens" class="block font-heading font-semibold text-white text-lg">Contactgegevens</label>
                    <input type="text" id="contactGegevens" name="contactGegevens"
                        class="w-full px-5 py-4 rounded-xl bg-[#0A0A0A] border border-white/10 text-white focus:outline-none focus:border-violet-500/50 focus:ring-4 focus:ring-violet-500/10 transition-all duration-300 font-medium placeholder-slate-600"
                        placeholder="E-mailadres of 06-nummer" />
                </div>
            </div>

            <div class="pt-4 border-t border-white/10">
                <button type="submit" id="submitBtn"
                    class="group w-full bg-white text-black font-heading font-bold text-lg py-5 rounded-xl shadow-[0_0_20px_rgba(255,255,255,0.2)] hover:shadow-[0_0_30px_rgba(255,255,255,0.4)] transform hover:-translate-y-1 transition-all duration-300 flex items-center justify-center gap-2">
                    <span id="submitText">Artikel Indienen</span>
                    <svg id="submitIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5 group-hover:translate-x-1 transition-transform">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
                    </svg>                      
                </button>
            </div>
        </form>
    </div>
</Layout>

<script>
    const form = document.getElementById('submissionForm') as HTMLFormElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const submitText = document.getElementById('submitText');
    const formFeedback = document.getElementById('formFeedback');
    
    // Voice to Text Logic
    const micButton = document.getElementById('micButton');
    const micStatus = document.getElementById('micStatus');
    const toelichtingInput = document.getElementById('toelichting') as HTMLTextAreaElement;
    
    // Check browser support
    if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
        micButton?.classList.remove('hidden');
        
        // @ts-ignore
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        const recognition = new SpeechRecognition();
        
        recognition.continuous = true; // Keep listening
        recognition.lang = 'nl-NL';
        recognition.interimResults = true; // Live feedback
        
        let isRecording = false;
        let finalTranscript = '';
        let originalText = '';

        recognition.onstart = () => {
            isRecording = true;
            micButton?.classList.add('text-red-500', 'bg-red-50');
            if (micButton) micButton.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 7.5A2.25 2.25 0 0 1 7.5 5.25h9a2.25 2.25 0 0 1 2.25 2.25v9a2.25 2.25 0 0 1-2.25 2.25h-9a2.25 2.25 0 0 1-2.25-2.25v-9Z" /></svg>`;
            micStatus?.classList.remove('hidden');
            
            if (toelichtingInput) {
                originalText = toelichtingInput.value;
                if (originalText && !originalText.endsWith(' ')) originalText += ' ';
            }
            finalTranscript = '';
        };
        
        recognition.onend = () => {
            isRecording = false;
            micButton?.classList.remove('text-red-500', 'bg-red-50');
            if (micButton) micButton.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z" /></svg>`;
            micStatus?.classList.add('hidden');
        };
        
        recognition.onresult = (event: any) => {
            let interimTranscript = '';
            for (let i = event.resultIndex; i < event.results.length; ++i) {
                if (event.results[i].isFinal) {
                    finalTranscript += event.results[i][0].transcript;
                } else {
                    interimTranscript += event.results[i][0].transcript;
                }
            }
            if (toelichtingInput) {
                toelichtingInput.value = originalText + finalTranscript + interimTranscript;
            }
        };
        
        micButton?.addEventListener('click', () => {
            if (isRecording) {
                recognition.stop();
            } else {
                recognition.start();
            }
        });
    }

    // File Upload Preview Logic
    const fileInput = document.getElementById('fotos') as HTMLInputElement;
    const dropzone = document.getElementById('dropzone');
    const filePreview = document.getElementById('filePreview');

    if (fileInput && dropzone && filePreview) {
        fileInput.addEventListener('change', (e) => {
            filePreview.innerHTML = ''; // Clear previous
            const files = fileInput.files;
            if (files && files.length > 0) {
                Array.from(files).forEach(file => {
                    const badge = document.createElement('div');
                    badge.className = 'px-3 py-1 bg-white border border-violet/20 text-violet text-xs font-bold rounded-lg shadow-sm truncate max-w-[150px] flex items-center gap-1';
                    
                    const icon = file.type.startsWith('video') ? '🎥' : '🖼️';
                    badge.innerHTML = `<span>${icon}</span><span class="truncate">${file.name}</span>`;
                    filePreview.appendChild(badge);
                });
            }
        });

        // Drag & Drop visual feedback
        fileInput.addEventListener('dragover', () => dropzone.classList.add('bg-violet/20', 'border-violet/60'));
        fileInput.addEventListener('dragleave', () => dropzone.classList.remove('bg-violet/20', 'border-violet/60'));
        fileInput.addEventListener('drop', () => dropzone.classList.remove('bg-violet/20', 'border-violet/60'));
    }

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!submitBtn || !submitText || !formFeedback) return;
        
        submitBtn.disabled = true;
        submitBtn.classList.add('opacity-75', 'cursor-not-allowed');
        submitText.innerText = 'Bezig met opslaan...';
        formFeedback.classList.add('hidden');
        
        const formData = new FormData(form);
        
        try {
            const response = await fetch('/api/submit-nieuws', {
                method: 'POST',
                body: formData
            });
            
            const result = await response.json();
            
            if (result.success) {
                formFeedback.innerText = result.message;
                formFeedback.className = 'p-4 rounded-xl text-center font-semibold mb-4 bg-green-100 text-green-800 transition-all block';
                form.reset();
            } else {
                throw new Error(result.error || 'Er ging iets fout bij het verzenden.');
            }
        } catch (error: any) {
            formFeedback.innerText = error.message;
            formFeedback.className = 'p-4 rounded-xl text-center font-semibold mb-4 bg-red-100 text-red-800 transition-all block';
        } finally {
            submitBtn.disabled = false;
            submitBtn.classList.remove('opacity-75', 'cursor-not-allowed');
            submitText.innerText = 'Artikel Indienen';
        }
    });
</script>
