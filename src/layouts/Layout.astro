---
import '@fontsource/inter';
import '@fontsource/outfit';
import '../styles/global.css';
import db from '../db/database';

interface Props {
	title: string;
}

const { title } = Astro.props;
const isAuthenticated = Astro.cookies.get('portal_auth')?.value === 'authenticated';

let siteTitle = "Content Portal";
let primaryColor = "#2D3FE0";
let logoUrl = "";

try {
    const res = await db.execute('SELECT site_title, primary_color, logo_url FROM settings WHERE id = 1');
    if (res.rows.length > 0) {
        siteTitle = String(res.rows[0].site_title || "Content Portal");
        primaryColor = String(res.rows[0].primary_color || "#2D3FE0");
        logoUrl = String(res.rows[0].logo_url || "");
    }
} catch (e) {
    console.error('Failed to load settings', e);
}

// Convert Hex to RGB for Tailwind Opacity support
function hexToRgb(hex: string) {
    const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
    return result ? `${parseInt(result[1], 16)} ${parseInt(result[2], 16)} ${parseInt(result[3], 16)}` : '45 63 224';
}
const brandRgb = hexToRgb(primaryColor);

// Adjust page title
let pageTitle = title.includes(siteTitle) ? title : `${title} - ${siteTitle}`;
if (title === siteTitle || title === "Home") pageTitle = siteTitle;
---

<!doctype html>
<html lang="nl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type={logoUrl ? "image/png" : "image/svg+xml"} href={logoUrl || "/favicon.svg"} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={`Aanlever tool voor ${siteTitle}.`} />
		<title>{pageTitle}</title>
        <style is:global define:vars={{ brandRgb: brandRgb }}>
            :root {
                --color-brand: var(--brandRgb);
            }
        </style>
	</head>
	<body class="grain bg-cream text-text font-sans antialiased min-h-screen flex flex-col">
		<header class="bg-white/80 backdrop-blur-md shadow-sm fixed w-full top-0 z-50 border-b border-warm-grey">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
                <a href="/" class="font-display font-bold text-2xl text-dark tracking-tight hover:opacity-80 transition-opacity flex items-center gap-3">
                    {logoUrl ? (
                        <img src={logoUrl} alt={`${siteTitle} Logo`} class="h-8 w-auto max-w-[120px] object-contain" />
                    ) : (
                        <div class="w-8 h-8 rounded-lg bg-brand flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="white" class="size-4">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
                            </svg>
                        </div>
                    )}
                    <span class={logoUrl ? "hidden sm:block" : ""}>{siteTitle}</span>
                </a>
                {isAuthenticated ? (
                    <a href="/dashboard" class="flex items-center gap-2 px-4 py-2.5 bg-brand text-white text-sm font-semibold rounded-xl hover:opacity-90 transition-all duration-200">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
                        </svg>
                        Dashboard
                    </a>
                ) : (
                    <a href="/login" class="flex items-center gap-2 px-4 py-2.5 bg-gray-100 text-dark text-sm font-semibold rounded-xl hover:bg-gray-200 transition-all duration-200">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
                        </svg>
                        Inloggen
                    </a>
                )}
            </div>
        </header>

		<main class="flex-grow pt-32 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto w-full mb-20 relative">
            <!-- Subtle background decoration -->
            <div class="fixed top-0 left-0 w-full h-full overflow-hidden -z-10 pointer-events-none">
                <div class="mesh-blob w-[600px] h-[600px] bg-brand/10 top-[10%] left-[-10%]" style="animation-delay: 0s;"></div>
                <div class="mesh-blob w-[500px] h-[500px] bg-violet/10 bottom-[-10%] right-[-5%]" style="animation-delay: -5s;"></div>
            </div>

			<slot />
		</main>
        
        <footer class="bg-dark text-white py-8 text-center text-sm mt-auto">
            <div class="max-w-7xl mx-auto px-4">
                <p class="opacity-50">&copy; {new Date().getFullYear()} Content Portal</p>
            </div>
        </footer>
	</body>
</html>

<script>
    // ── Scroll Reveal ──────────────────────────
    const revealObserver = new IntersectionObserver(
    (entries) => {
        entries.forEach((entry) => {
        if (entry.isIntersecting) {
            entry.target.classList.add("visible");
        }
        });
    },
    { threshold: 0.1, rootMargin: "0px 0px -60px 0px" },
    );

    document
    .querySelectorAll(".reveal")
    .forEach((el) => revealObserver.observe(el));
</script>
