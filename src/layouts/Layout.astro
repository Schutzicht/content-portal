---
import '@fontsource/inter';
import '@fontsource/outfit';
import '../styles/global.css';
import db from '../db/database';

interface Props {
	title: string;
}

const { title } = Astro.props;
const isAuthenticated = Astro.cookies.get('portal_auth')?.value === 'authenticated';

let siteTitle = "Content Portal";
let primaryColor = "#2D3FE0";
let logoUrl = "";

try {
    const res = await db.execute('SELECT site_title, primary_color, logo_url FROM settings WHERE id = 1');
    if (res.rows.length > 0) {
        siteTitle = String(res.rows[0].site_title || "Content Portal");
        primaryColor = String(res.rows[0].primary_color || "#2D3FE0");
        logoUrl = String(res.rows[0].logo_url || "");
    }
} catch (e) {
    console.error('Failed to load settings', e);
}

// Convert Hex to RGB for Tailwind Opacity support
function hexToRgb(hex: string) {
    const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
    return result ? `${parseInt(result[1], 16)} ${parseInt(result[2], 16)} ${parseInt(result[3], 16)}` : '45 63 224';
}
const brandRgb = hexToRgb(primaryColor);

// Adjust page title
let pageTitle = title.includes(siteTitle) ? title : `${title} - ${siteTitle}`;
if (title === siteTitle || title === "Home") pageTitle = siteTitle;
---

<!doctype html>
<html lang="nl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type={logoUrl ? "image/png" : "image/svg+xml"} href={logoUrl || "/favicon.svg"} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={`Aanlever tool voor ${siteTitle}.`} />
		<title>{pageTitle}</title>
        <style is:global define:vars={{ brandRgb: brandRgb }}>
            :root {
                --color-brand: var(--brandRgb);
            }
        </style>
	</head>
	<body class="bg-[#050505] text-slate-100 font-sans antialiased min-h-screen flex flex-col selection:bg-brand selection:text-white overflow-x-hidden">
        
        <!-- Dynamic Glowing Aurora Background -->
        <div class="fixed inset-0 z-[-1] overflow-hidden pointer-events-none bg-[#050505]">
            <div class="absolute top-[-20%] left-[-10%] w-[70vw] h-[70vw] rounded-full bg-brand/20 blur-[120px] mix-blend-screen animate-aurora origin-center opacity-60"></div>
            <div class="absolute bottom-[-20%] right-[-10%] w-[60vw] h-[60vw] rounded-full bg-indigo-600/20 blur-[120px] mix-blend-screen animate-aurora origin-[50%_100%] opacity-50 animation-delay-2000"></div>
            <div class="absolute top-[20%] right-[10%] w-[40vw] h-[40vw] rounded-full bg-violet-600/15 blur-[100px] mix-blend-screen animate-pulse-slow opacity-40"></div>
            
            <!-- Grid overlay for texture -->
            <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0MCIgaGVpZ2h0PSI0MCI+PHBhdGggZD0iTTAgMGg0MHY0MEgweiIgZmlsbD0ibm9uZSIvPPHBhdGggZD0iTTAgMGg0MHYxSDB6bTAgNDBoMXYtNDBoLTEiIGZpbGw9InJnYmEoMjU1LDI1NSwyNTUsMC4wMykiLz48L3N2Zz4=')] opacity-30"></div>
        </div>

        <header class="sticky top-0 z-40 bg-[#050505]/70 backdrop-blur-2xl border-b border-white/5 transition-all duration-300" id="main-header">
            <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
                
                <a href="/" class="flex items-center gap-3 group">
                    <div class="relative w-10 h-10 flex-shrink-0 bg-white shadow-lg shadow-white/5 rounded-xl overflow-hidden flex justify-center items-center border border-white/10 group-hover:scale-105 transition-transform">
                        <img src={logoUrl || "/favicon.svg"} alt="Logo" class="max-w-full max-h-full object-contain p-2" />
                    </div>
                    <div>
                        <span class="font-display font-bold text-xl text-white tracking-tight">{siteTitle}</span>
                        <div class="h-0.5 w-0 bg-brand group-hover:w-full transition-all duration-300 ease-out"></div>
                    </div>
                </a>
                
                {isAuthenticated ? (
                    <div class="flex items-center gap-4">
                        <a href="/dashboard" class="hidden sm:flex items-center gap-2 text-sm font-semibold text-slate-300 hover:text-white transition-colors">
                            <span class="w-2 h-2 rounded-full bg-brand animate-pulse"></span>
                            Dashboard
                        </a>
                        <form action="/api/logout" method="POST">
                            <button type="submit" class="p-2 text-slate-400 hover:text-brand bg-white/5 hover:bg-brand/10 border border-white/5 rounded-xl transition-all" aria-label="Uitloggen" title="Uitloggen">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
                                </svg>
                            </button>
                        </form>
                    </div>
                ) : (
                    <a href="/login" class="flex items-center gap-2 px-4 py-2.5 bg-white/5 text-white text-sm font-semibold rounded-xl hover:bg-white/10 border border-white/10 transition-all duration-200">
                        Inloggen
                    </a>
                )}
            </div>
        </header>

		<main class="flex-grow pt-32 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto w-full mb-20 relative">
            <slot />
        </main>
        
        <footer class="bg-dark text-white py-8 text-center text-sm mt-auto">
            <div class="max-w-7xl mx-auto px-4">
                <p class="opacity-50">&copy; {new Date().getFullYear()} Content Portal</p>
            </div>
        </footer>
	</body>
</html>

<script>
    // ── Scroll Reveal ──────────────────────────
    const revealObserver = new IntersectionObserver(
    (entries) => {
        entries.forEach((entry) => {
        if (entry.isIntersecting) {
            entry.target.classList.add("visible");
        }
        });
    },
    { threshold: 0.1, rootMargin: "0px 0px -60px 0px" },
    );

    document
    .querySelectorAll(".reveal")
    .forEach((el) => revealObserver.observe(el));
</script>
